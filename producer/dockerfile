# Bước 1: Build file JAR (Dùng Maven)
FROM maven:3.9.6-eclipse-temurin-21-alpine AS build
WORKDIR /producer
COPY pom.xml .
COPY src ./src
RUN mvn clean package -DskipTests -Dstart-class=com.example.producer.SeederApplication


FROM eclipse-temurin:21-jre-alpine
WORKDIR /producer
COPY --from=build /producer/target/*.jar app.ja
ENTRYPOINT ["java", "-jar", "app.jar"]
EXPOSE 8080